# ─────────────────────────────────────────────────
#  ClareerHQ — Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────────

# ── O*NET API ─────────────────────────────────────
# Register free at: https://services.onetcenter.org/developer/
ONET_USERNAME=your_onet_username
ONET_PASSWORD=your_onet_password

# ── Database (Neon PostgreSQL) ────────────────────
# Create free DB at: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Clerk Auth ────────────────────────────────────
# Create app at: https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/assess

# ── Stripe ────────────────────────────────────────
# Get keys at: https://stripe.com/docs/keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...

# ── Resend Email ──────────────────────────────────
# Create free account at: https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@clareerhq.com

# ── PostHog Analytics ─────────────────────────────
# Create free account at: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
